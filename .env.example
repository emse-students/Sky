# SSO Authentik (miconnect) - app Sky
# Issuer : le slug doit correspondre a l app Sky dans Authentik.
MICONNECT_ISSUER=https://auth.canari-emse.fr/application/o/sky
MICONNECT_CLIENT_ID=your_client_id_here
MICONNECT_CLIENT_SECRET=your_client_secret_here

# Sub Authentik des admins (separes par des virgules), facultatif
SKY_ADMIN_SUBS=

# API MiGallery (photos de profil)
MIGALLERY_API_KEY=your_api_key_here
MIGALLERY_API_URL=https://gallery.mitv.fr

# Database path (optional, defaults to database/sky.db)
# DATABASE_PATH=database/sky.db
