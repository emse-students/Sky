{
  "name": "sky-sveltekit",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=24.0.0",
    "bun": "*"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "check": "npm run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "npm run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint src/lib --ext .ts,.tsx,.js,.jsx --cache && eslint src/routes --ext .ts,.tsx,.js,.jsx --cache",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --ignore-pattern 'scripts/**' --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deps:install": "bun install",
    "deps:install:pnpm": "pnpm install",
    "deps:install:npm": "npm install",
    "ci:install": "bun install --production",
    "ci:build": "bun install --production && npm run build",
    "prebuild": "npm run deps:install || npm run deps:install:pnpm || npm run deps:install:npm || true",
    "start": "bun run dev",
    "start:prod": "node scripts/init-db.js && node scripts/migrate-add-bio.js && node scripts/migrate-auth.js && node scripts/rebuild-db.js && node --env-file=.env build/index.js",
    "db:init": "node scripts/init-db.js",
    "package": "bun run build && bun ./scripts/pack-bun.js",
    "package:legacy": "npm run build && node -e \"require('fs').mkdirSync('build/artifacts',{ recursive: true })\" && npm pack --pack-destination build/artifacts",
    "version:show": "node -e \"console.log(require('./package.json').version)\"",
    "test": "echo 'No tests implemented yet'"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@inlang/paraglide-js": "^2.22.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-node": "^5.5.7",
    "@sveltejs/kit": "^2.70.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/better-sqlite3": "^7.6.13",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "autoprefixer": "^10.5.4",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.22.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.6",
    "svelte-check": "^4.7.3",
    "svelte-eslint-parser": "^1.6.0",
    "tailwindcss": "^4.3.1",
    "tar": "^7.5.20",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@humanspeak/svelte-markdown": "^1.6.0",
    "better-sqlite3": "^12.11.1",
    "graphology": "^0.26.0",
    "graphology-components": "^1.5.4",
    "graphology-layout": "^0.6.1",
    "graphology-layout-forceatlas2": "^0.10.1",
    "lucide-svelte": "^1.0.1"
  }
}
